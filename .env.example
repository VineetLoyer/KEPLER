# KEPLER API Configuration
KEPLER_API_HOST=0.0.0.0
KEPLER_API_PORT=8000
KEPLER_API_CORS_ORIGINS=*
KEPLER_API_ENVIRONMENT=development
KEPLER_API_LOG_LEVEL=INFO

# KEPLER System Configuration (from existing config)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
BING_SEARCH_API_KEY=your_bing_key_here
GOOGLE_VISION_API_KEY=your_google_vision_key_here

# System Settings
MAX_SEARCH_RESULTS=10
MAX_EVIDENCE_PIECES=20
